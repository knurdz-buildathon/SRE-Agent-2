# SRE Agent Configuration
DATABASE_PATH=/data/sre.db
TRAEFIK_LOG_DIR=/traefik-logs
USER_LOG_DIR=/user-logs
DOCKER_SOCKET=/var/run/docker.sock
HOST_PROC_ROOT=/host-proc
HOST_ETC_ROOT=/host-etc
HOST_ROOT=/host-root
CHECK_INTERVAL=30
HEALTH_CHECK_INTERVAL_SECONDS=30
DASHBOARD_USER=admin
DASHBOARD_PASS=admin
DEMO_MODE=false

# Auto-discovery (published host ports → Overview without labels on each service)
AUTO_DISCOVER_WEB=true
PROBE_HOST=host.docker.internal
SRE_AGENT_CONTAINER_NAME=sre-agent-api
AUTO_DISCOVER_SKIP_CONTAINERS=sre-agent-api,sre-agent-web
AUTO_DISCOVER_SKIP_HOST_PORTS=3306,5432,5433,6379,6380,27017,5672,9092,2181,8500,25,22,51820
AUTO_DISCOVER_ORPHANS=false
AUTO_BROWSER_AUTO=false

# VPS-wide scanning — paths inside container (host mounts, see docker-compose)
VPS_SCAN_ENABLED=true
# HOST_PROC_NET_TCP=/host-proc/net/tcp
HOST_DISK_PATH=/host-root
HOST_CPU_SAMPLE_SECONDS=0.1

# HTTP probes (reduce false "down" when vhosts / TLS-only edges respond oddly)
HTTP_TIMEOUT=15
HTTP_VERIFY_SSL=true
# strict: only 2xx–3xx count as up | reachable: any HTTP status counts as up
# Default is reachable — if a server returns ANY HTTP status the port/TLS is alive.
# Real outages manifest as timeouts / connection failures (still → down).
HTTP_AVAILABILITY_MODE=reachable
HTTP_TRY_HTTPS_FALLBACK=true
HTTP_PROBE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/122.0.0.0 Safari/537.36 SRE-Agent/1.0
# When health URL path is "/" only, try these paths on the same origin if probes fail (wrong path / strict mode)
HTTP_PROBE_TRY_FALLBACK_PATHS=true
HTTP_PROBE_FALLBACK_PATHS=/health,/healthz,/ready,/status,/api/health,/live,/ping

# HTTPS to gateway (PROBE_HOST): TLS SNI = probe hostname (like curl --resolve)
HTTP_PROBE_GATEWAY_SNI=true
# HTTP_PROBE_GATEWAY_HOSTS=

# Consecutive HTTP failures before marking deployment **down**
HEALTH_DOWN_AFTER_FAILURES=3

# User/app log ingestion
# Mount application access/error logs to USER_LOG_DIR; JSON, jsonl, log, txt, and access files are parsed incrementally.
LOG_MAX_BYTES_PER_FILE=2000000
